

{
	order authenticate before respond
	order authorize before basicauth

	security {
		oauth identity provider tsidp {
			realm tsidp
			driver generic
			client_id "unused"
			client_secret "unused"
			scopes openid email profile
			metadata_url https://auth.scuffedflix.no/.well-known/openid-configuration
		}
		authorization policy foundry_policy {
			set auth url https://auth.scuffedflix.no
			crypto key sign-verify {env.JWT_SEED}
			allow roles authp/user
			acl rule {
				comment allow users to access foundry
				match role authp/user
				allow stop
			}
		}

		authentication portal tsidp {
			enable identity provider tsidp

			transform user {
				match realm tsidp
				action add role authp/user
				action add header X-Webauth-Email {claims.email}
			}

			ui {
				links {
					"Foundry VTT" "/game" icon "game"
				}
			}
		}
	}
}

foundryvtt.scuffedflix.no {
	handle {
		authorize with foundry_policy
		exec /home/oddbjornmr/nixos/common/services/check-foundry-user.sh {header.X-Webauth-Email} {
			output headers
		}
		reverse_proxy localhost:30000
	}
}
